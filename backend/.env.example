# Backend Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# Salesforce Configuration (Required)
# ===========================================
# Get from Salesforce Connected App settings
SF_TOKEN_URL=https://your-instance.salesforce.com/services/oauth2/token
SF_CLIENT_ID=your-client-id
SF_CLIENT_SECRET=your-client-secret
SF_INSTANCE_URL=https://your-instance.salesforce.com

# ===========================================
# Server Configuration
# ===========================================
PORT=8080

# ===========================================
# Development Options
# ===========================================
# Skip LIFF token verification (development only, set to false in production)
SKIP_LIFF_AUTH=false
