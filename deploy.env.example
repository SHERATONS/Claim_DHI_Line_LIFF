# ─────────────────────────────────────────────────────────────────────────────
# DEPLOY CONFIGURATION TEMPLATE
# Copy this file to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — NEVER commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud Run ────────────────────────────────────────────────────────────────
CR_SERVICE_NAME=claim-backend
CR_FRONTEND_SERVICE_NAME=claim-frontend
CR_REGION=asia-southeast1

# ── Salesforce ───────────────────────────────────────────────────────────────
SF_TOKEN_URL=https://YOUR_SF_DOMAIN.sandbox.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=YOUR_CONNECTED_APP_CLIENT_ID
SF_CLIENT_SECRET=YOUR_CONNECTED_APP_CLIENT_SECRET
SF_INSTANCE_URL=https://YOUR_SF_DOMAIN.sandbox.my.salesforce.com

# ── LINE LIFF ────────────────────────────────────────────────────────────────
LIFF_CHANNEL_ID=2009262937

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to true ONLY for local dev / integration testing — never in production
SKIP_LIFF_AUTH=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the backend
# Add your Cloud Run frontend URL and any custom domain here
ALLOWED_ORIGINS=https://YOUR_FRONTEND_CLOUD_RUN_URL
