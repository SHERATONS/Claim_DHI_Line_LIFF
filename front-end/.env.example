# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# LIFF Configuration (Required)
# ===========================================
# Get this from LINE Developers Console
VITE_LIFF_ID=your-liff-id-here

# ===========================================
# API Configuration (Required)
# ===========================================
# Backend API base URL (Cloud Run service URL)
VITE_API_URL=https://your-cloud-run-service.run.app

# ===========================================
# Development Options
# ===========================================
# Enable mock data for testing without backend
VITE_USE_MOCK_DATA=false

# Download claim as local ZIP instead of submitting (dev only)
VITE_USE_LOCAL_SAVE=false
