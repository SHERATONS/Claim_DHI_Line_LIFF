    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "happy-dom": "^20.1.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.0"
